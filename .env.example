# No commitear .env ni archivos JSON de cuenta de servicio.
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
PLANTILLA_DRIVE_FILE_ID=
CONTROL_SHEET_ID=
CONTROL_SHEET_TAB_TARJETAS=Tarjetas
CONTROL_SHEET_TAB_HISTORICO=historico_proveedores
HISTORICO_DRIVE_FOLDER_ID=
SERVICE_ACCOUNT_EMAIL=
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v2
# Verificación SSL al consultar Frankfurter. false solo en red corporativa con proxy HTTPS.
FX_SSL_VERIFY=true
AMOUNT_TOLERANCE_PCT=0.02
# Tolerancia ampliada para facturas SOL (propinas en terminal Perú), con o sin amount_original en el preliminar.
AMOUNT_TOLERANCE_PCT_SOL=0.12
DATE_TOLERANCE_DAYS=3
TZ=America/Bogota
CONSOLIDATED_RECEIPT_MAX_DAYS_AFTER=30
# Meses calendario máximos entre cargo y recibo consolidado en fase de revisión (amarillo).
CONSOLIDATED_RECEIPT_REVIEW_MAX_MONTHS=3
IVA_RATE_COP=0.19
# Keywords (coma-separadas) para omitir desglose IVA en facturas COP de restaurante.
RESTAURANT_NO_IVA_KEYWORDS=RESTAURANTE,ALMUERZO,CENA,COMIDA,GASTO DE REPRESENTACION
ARTICULO_PROPINA=0000000000 - GASTOS NO DEDUCIBLES
